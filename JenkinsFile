pipeline{
    agent any
    parameters{
        booleanParam(name:'ALLURE', defaultValue: false, description: 'generation de rapport allure')
        booleanParam(name: 'isbrowser', defaultValue: false, description: 'executer avec ou sans browser')
        choice(name: 'browser', choices: ['edge','chromium','electron'], description: 'Choisissez le choix du navigateur')   
    }
    stages{
        stage('global stage'){
            agent{
                docker{
                    image 'cypress/included:latest'
                    args '-u root --entrypoint='
                }
            }
            stages{
                stage('install deps'){
                    steps{
                        sh 'npm ci'
                    }
                }
                stage('clean allure results'){
                    steps{
                        sh '''
                            echo "Suppression du cache Allure..."
                            rm -rf allure-results
                            mkdir -p allure-results
                            echo "Dossier allure-results nettoyé avec succès"
                        '''
                    }
                }
                stage('run user test'){
                    steps{  
                        script{
                            if(params.ALLURE){
                                if(params.isbrowser){
                                    sh "npx cypress run --browser ${params.browser} --env allure=true"  
                                } else {
                                    sh "npx cypress run --env allure=true"
                                }                              
                                stash name: 'allure-results', includes: 'allure-results/*', allowEmpty: true // ✅
                            } else {
                                if(params.isbrowser){
                                    sh "npx cypress run --browser ${params.browser}"  
                                } else {
                                    sh "npx cypress run"
                                } 
                            }
                        }
                    }
                }
            }
        }
    }
    post{
        always{
            script{
                if(params.ALLURE){
                    unstash 'allure-results'
                    archiveArtifacts 'allure-results/*'
                    allure includeProperties: false,
                           jdk: '',
                           results: [[path: 'allure-results/']]
                }
            }
        }
    }
}
